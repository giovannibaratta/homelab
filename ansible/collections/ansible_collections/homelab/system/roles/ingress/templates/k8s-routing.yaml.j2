# ##############################################################################
# KUBERNETES ROUTING CONFIGURATION
# 
# This file is dynamically generated by Ansible. It bridges the external
# Traefik gateway to the internal Kubernetes Ingress controller.
# ##############################################################################

http:
  routers:
{% for domain in k8s_public_domains | default([]) %}
    # Public Router for {{ domain }}.{{ internal_domain }} (Reachable from WAN & LAN)
    k8s-public-{{ loop.index }}:
      rule: "Host(`{{ domain }}.{{ internal_domain }}`)"
      entryPoints:
        - public-secure
        - websecure
      service: k8s-ingress-svc
      tls:
        certResolver: letsencrypt
      middlewares:
        - rateLimit@file
        - inFlightReq@file
        - waf@file
{% endfor %}

{% for domain in k8s_internal_domains | default([]) %}
    # Internal Router for {{ domain }}.{{ internal_domain }} (Reachable from LAN ONLY)
    k8s-internal-{{ loop.index }}:
      rule: "Host(`{{ domain }}.{{ internal_domain }}`)"
      entryPoints:
        - websecure
      service: k8s-ingress-svc
      tls:
        certResolver: letsencrypt
      middlewares:
        - rateLimit@file
        - inFlightReq@file
{% endfor %}

  services:
    # This service points to the internal Kubernetes Ingress Controller's LoadBalancer IP.
    # It communicates via plain HTTP (port 80) as TLS and WAF are handled by this gateway.
    k8s-ingress-svc:
      loadBalancer:
        servers:
          - url: "http://{{ k8s_ingress_lb_ip }}:80"
