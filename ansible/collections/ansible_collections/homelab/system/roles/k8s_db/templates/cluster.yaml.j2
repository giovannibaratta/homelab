apiVersion: postgresql.cnpg.io/v1
kind: Cluster
metadata:
  name: {{ __k8s_db_cluster_name }}
  namespace: {{ k8s_db_cluster_namespace }}
spec:
  instances: 3

  bootstrap:
    initdb:
      database: {{ __k8s_db_cluster_name }}
      owner: {{ __k8s_db_db_user }}
      secret:
        name: {{ __k8s_db_secret_name }}

  affinity:
    podAntiAffinityType: required

  storage:
    size: {{ __k8s_db_storage_size }}
    storageClass: local-storage

  type: rw

{% if __k8s_db_resources is defined %}
  resources:
    {{ __k8s_db_resources | to_nice_yaml(indent=2) | indent(4) }}
{% endif %}
{% if __k8s_db_priority_class_name is defined %}
  priorityClassName: {{ __k8s_db_priority_class_name }}
{% endif %}


  serviceTemplate:
    spec:
      type: LoadBalancer

  managed:
    services:
      disabledDefaultServices: ["ro", "r"]
      additional:
        - selectorType: rw
          serviceTemplate:
            metadata:
              name: "{{ __k8s_db_cluster_name }}-lb"
            spec:
              type: LoadBalancer
