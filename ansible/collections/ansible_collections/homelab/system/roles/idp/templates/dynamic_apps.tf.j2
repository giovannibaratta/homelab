{% for app in idp_dynamic_apps | default([]) %}
resource "zitadel_project" "{{ app.name }}" {
  name                     = "{{ app.name }}"
  org_id                   = data.zitadel_org.org.id
  project_role_assertion   = {{ app.project_role_assertion | default('true') | lower }}
  project_role_check       = {{ app.project_role_check | default('false') | lower }}
  has_project_check        = {{ app.has_project_check | default('false') | lower }}
  private_labeling_setting = "PRIVATE_LABELING_SETTING_ENFORCE_PROJECT_RESOURCE_OWNER_POLICY"
}

resource "zitadel_application_oidc" "{{ app.name }}" {
  project_id = zitadel_project.{{ app.name }}.id
  org_id     = data.zitadel_org.org.id

  name                        = "{{ app.name }}"
  redirect_uris               = {{ app.redirect_uris | to_json }}
  response_types              = ["OIDC_RESPONSE_TYPE_CODE"]
  grant_types                 = ["OIDC_GRANT_TYPE_AUTHORIZATION_CODE", "OIDC_GRANT_TYPE_REFRESH_TOKEN"]
  post_logout_redirect_uris   = {{ app.post_logout_redirect_uris | default([]) | to_json }}
  app_type                    = "{{ app.app_type | default('OIDC_APP_TYPE_WEB') }}"
  auth_method_type            = "{{ app.auth_method_type | default('OIDC_AUTH_METHOD_TYPE_BASIC') }}"
  version                     = "OIDC_VERSION_1_0"
  clock_skew                  = "0s"
  dev_mode                    = {{ app.dev_mode | default('false') | lower }}
  access_token_type           = "{{ app.access_token_type | default('OIDC_TOKEN_TYPE_JWT') }}"
  access_token_role_assertion = {{ app.access_token_role_assertion | default('true') | lower }}
  id_token_role_assertion     = {{ app.id_token_role_assertion | default('false') | lower }}
  id_token_userinfo_assertion = {{ app.id_token_userinfo_assertion | default('false') | lower }}
  additional_origins          = []
}

output "{{ app.name }}_client_id" {
  value     = zitadel_application_oidc.{{ app.name }}.client_id
  sensitive = true
}

output "{{ app.name }}_client_secret" {
  value     = zitadel_application_oidc.{{ app.name }}.client_secret
  sensitive = true
}
{% endfor %}
