apiVersion: apps/v1
kind: Deployment
metadata:
  name: netbird-signal
  namespace: {{ k8s_netbird_namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: netbird-signal
  template:
    metadata:
      labels:
        app: netbird-signal
    spec:
      containers:
        - name: signal
          image: netbirdio/signal:{{ k8s_netbird_signal_version }}
          ports:
            - containerPort: 80
              name: grpc
          livenessProbe:
            tcpSocket:
              port: grpc
            initialDelaySeconds: 5
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            tcpSocket:
              port: grpc
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 2
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              cpu: 500m
              memory: 256Mi
---
apiVersion: v1
kind: Service
metadata:
  name: netbird-signal
  namespace: {{ k8s_netbird_namespace }}
  annotations:
    traefik.ingress.kubernetes.io/service.serversscheme: h2c
spec:
  ports:
    - port: 80
      targetPort: grpc
      name: grpc
  selector:
    app: netbird-signal
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: netbird-signal
  namespace: {{ k8s_netbird_namespace }}
spec:
  ingressClassName: traefik
  rules:
    - host: netbird.{{ internal_domain }}
      http:
        paths:
          - path: /signalexchange.SignalExchange/
            pathType: Prefix
            backend:
              service:
                name: netbird-signal
                port:
                  number: 80
