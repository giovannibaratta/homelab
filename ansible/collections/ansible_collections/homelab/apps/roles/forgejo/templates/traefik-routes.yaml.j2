---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: forgejo-web
  namespace: {{ forgejo_namespace }}
spec:
  entryPoints:
    - web
    - websecure
  routes:
    - match: Host(`{{ forgejo_domain }}`)
      kind: Rule
      services:
        - name: forgejo-http
          port: 3000

---
apiVersion: traefik.io/v1alpha1
kind: IngressRouteTCP
metadata:
  name: forgejo-ssh
  namespace: {{ forgejo_namespace }}
spec:
  entryPoints:
    - git-ssh
  routes:
    - match: HostSNI(`*`)
      services:
        - name: forgejo-ssh
          port: 22
